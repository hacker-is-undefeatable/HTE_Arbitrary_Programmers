# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Azure OpenAI API (HKUST)
AZURE_OPENAI_API_KEY=your_hkust_azure_api_key_here
AZURE_OPENAI_ENDPOINT=https://hkust.azure-api.net/openai
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-21

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
DATABASE_URL=your_supabase_db_url_here

# NFT Badge (Sepolia)
SEPOLIA_RPC_URL=your_sepolia_rpc_url_here
NFT_BADGE_CONTRACT_ADDRESS=your_nft_badge_contract_address_here
NFT_BADGE_MINTER_PRIVATE_KEY=your_minter_wallet_private_key_here
NFT_BADGE_IMAGE_URL=your_badge_image_url_here

# ScholarFly ERC20 Reward Token (Sepolia)
SCHOLARFLY_TOKEN_CONTRACT_ADDRESS=your_scholarfly_token_contract_address_here
SCHOLARFLY_TOKEN_REWARD_AMOUNT=10
SCHOLARFLY_TOKEN_DECIMALS=18

# Environment Mode
NODE_ENV=development
